{
  "version": 2,
  "builds": [
    {
      "src": "api-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api-server.js"
    },
    {
      "src": "/app/admin",
      "dest": "/public/app/admin/index.html"
    },
    {
      "src": "/app/admin/(.*)",
      "dest": "/public/app/admin/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/public/app/index.html"
    },
    {
      "src": "/app",
      "dest": "/public/app/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
